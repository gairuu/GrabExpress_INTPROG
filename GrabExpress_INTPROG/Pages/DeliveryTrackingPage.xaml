<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GrabExpress_INTPROG.Pages.DeliveryTrackingPage"
             Title="Tracking"
             BackgroundColor="#F0F4F8"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <!-- Header (title changes dynamically per role) -->
        <Border Grid.Row="0" BackgroundColor="#00B14F" StrokeThickness="0" Padding="20,15">
            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Button Text="⬅" TextColor="White" BackgroundColor="Transparent" FontSize="18" Padding="0" Margin="0,0,4,0"
                        WidthRequest="30" HeightRequest="30" Clicked="OnBackClicked" VerticalOptions="Center" />
                <Label x:Name="HeaderIcon" Text="📦" FontSize="22" VerticalOptions="Center"/>
                <Label x:Name="HeaderTitle" Text="Track My Delivery" TextColor="White"
                       FontSize="20" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- Status Badge -->
                <Border x:Name="StatusBadge"
                        BackgroundColor="#E8F5E9" StrokeThickness="0"
                        StrokeShape="RoundRectangle 30" Padding="20,12"
                        HorizontalOptions="Center" Margin="0,4,0,0">
                    <Label x:Name="StatusLabel"
                           Text="SEARCHING FOR DRIVER..." FontSize="14"
                           FontAttributes="Bold" TextColor="#00B14F"
                           HorizontalOptions="Center"/>
                </Border>

                <!-- ══════════════════════════════════════════
                     CUSTOMER-ONLY SECTION
                     ══════════════════════════════════════════ -->

                <!-- Delivery Progress Steps (Customer Only) -->
                <Border x:Name="ProgressCard" BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 16" Padding="20" IsVisible="False">
                    <Border.Shadow>
                        <Shadow Brush="#00000015" Offset="0,4" Radius="12" Opacity="0.15"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Delivery Progress" FontAttributes="Bold" FontSize="15" TextColor="#1A1A1A"/>

                        <HorizontalStackLayout Spacing="14" VerticalOptions="Center">
                            <Border x:Name="Step1Badge" BackgroundColor="#00B14F" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20" WidthRequest="32" HeightRequest="32">
                                <Label Text="✓" TextColor="White" FontSize="14" FontAttributes="Bold"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label Text="Booking Confirmed" FontAttributes="Bold" FontSize="13" TextColor="#1A1A1A"/>
                                <Label Text="Your request has been placed" FontSize="11" TextColor="#757575"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <BoxView x:Name="Line1" HeightRequest="2" Margin="12,0,0,0"
                                 HorizontalOptions="Start" WidthRequest="2" BackgroundColor="#00B14F"/>

                        <HorizontalStackLayout Spacing="14" VerticalOptions="Center">
                            <Border x:Name="Step2Badge" BackgroundColor="#E0E0E0" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20" WidthRequest="32" HeightRequest="32">
                                <Label x:Name="Step2Icon" Text="2" TextColor="#999999" FontSize="14"
                                       FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label x:Name="Step2Title" Text="Driver Assigned" FontAttributes="Bold"
                                       FontSize="13" TextColor="#AAAAAA"/>
                                <Label x:Name="Step2Sub" Text="Waiting for a driver to accept"
                                       FontSize="11" TextColor="#BBBBBB"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <BoxView x:Name="Line2" HeightRequest="2" Margin="12,0,0,0"
                                 HorizontalOptions="Start" WidthRequest="2" BackgroundColor="#E0E0E0"/>

                        <HorizontalStackLayout Spacing="14" VerticalOptions="Center">
                            <Border x:Name="Step3Badge" BackgroundColor="#E0E0E0" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20" WidthRequest="32" HeightRequest="32">
                                <Label x:Name="Step3Icon" Text="3" TextColor="#999999" FontSize="14"
                                       FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label x:Name="Step3Title" Text="On The Way" FontAttributes="Bold"
                                       FontSize="13" TextColor="#AAAAAA"/>
                                <Label x:Name="Step3Sub" Text="Driver is heading to you"
                                       FontSize="11" TextColor="#BBBBBB"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <BoxView x:Name="Line3" HeightRequest="2" Margin="12,0,0,0"
                                 HorizontalOptions="Start" WidthRequest="2" BackgroundColor="#E0E0E0"/>

                        <HorizontalStackLayout Spacing="14" VerticalOptions="Center">
                            <Border x:Name="Step4Badge" BackgroundColor="#E0E0E0" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20" WidthRequest="32" HeightRequest="32">
                                <Label x:Name="Step4Icon" Text="4" TextColor="#999999" FontSize="14"
                                       FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label x:Name="Step4Title" Text="Delivered" FontAttributes="Bold"
                                       FontSize="13" TextColor="#AAAAAA"/>
                                <Label x:Name="Step4Sub" Text="Package delivered successfully"
                                       FontSize="11" TextColor="#BBBBBB"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Driver Info Card (Customer Only) -->
                <Border x:Name="DriverCard" BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 16" Padding="20" IsVisible="False">
                    <Border.Shadow>
                        <Shadow Brush="#00000015" Offset="0,4" Radius="12" Opacity="0.15"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Your Driver" FontAttributes="Bold" FontSize="15" TextColor="#1A1A1A"/>
                        <HorizontalStackLayout Spacing="14">
                            <Border BackgroundColor="#E8F5E9" StrokeThickness="0" StrokeShape="RoundRectangle 30"
                                    WidthRequest="52" HeightRequest="52">
                                <Label Text="🧑" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label x:Name="DriverNameLabel" Text="Searching for driver..."
                                       FontAttributes="Bold" FontSize="16" TextColor="#1A1A1A"/>
                                <Label x:Name="VehicleLabel" Text="" FontSize="13"
                                       TextColor="#757575" IsVisible="False"/>
                                <Label x:Name="ContactLabel" Text="" FontSize="13"
                                       TextColor="#00B14F" IsVisible="False"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ══════════════════════════════════════════
                     DRIVER-ONLY SECTION
                     ══════════════════════════════════════════ -->

                <!-- Delivery Route Card -->
                <Border x:Name="DeliveryRouteCard" BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 16" Padding="20">
                    <Border.Shadow>
                        <Shadow Brush="#00000015" Offset="0,4" Radius="12" Opacity="0.15"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Delivery Route" FontAttributes="Bold" FontSize="15" TextColor="#1A1A1A"/>
                        <HorizontalStackLayout Spacing="14">
                            <VerticalStackLayout Spacing="6" WidthRequest="20" VerticalOptions="Center">
                                <Border BackgroundColor="#00B14F" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 6"
                                        WidthRequest="12" HeightRequest="12" HorizontalOptions="Center"/>
                                <BoxView BackgroundColor="#DDDDDD" WidthRequest="2"
                                         HeightRequest="28" HorizontalOptions="Center"/>
                                <Border BackgroundColor="#e74c3c" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 6"
                                        WidthRequest="12" HeightRequest="12" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="12" HorizontalOptions="FillAndExpand">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="PICKUP" FontSize="11" TextColor="#AAAAAA" FontAttributes="Bold"/>
                                    <Label x:Name="RoutePickupLabel" Text="—"
                                           FontAttributes="Bold" FontSize="14" TextColor="#1A1A1A"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="DROP-OFF" FontSize="11" TextColor="#AAAAAA" FontAttributes="Bold"/>
                                    <Label x:Name="RouteDropoffLabel" Text="—"
                                           FontSize="14" TextColor="#555555"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Action Buttons -->

                <!-- Mark as Delivered (Driver Only) -->
                <Button x:Name="CompleteButton" Text="✅  MARK AS DELIVERED"
                        BackgroundColor="#00B14F" TextColor="White"
                        CornerRadius="12" HeightRequest="52" FontAttributes="Bold"
                        IsVisible="False" Clicked="OnCompleteClicked" Margin="0,4,0,0"/>

                <!-- Proceed to Payment (Customer Only, when Delivered) -->
                <Button x:Name="PayButton" Text="💳  PROCEED TO PAYMENT"
                        BackgroundColor="#1565C0" TextColor="White"
                        CornerRadius="12" HeightRequest="52" FontAttributes="Bold"
                        IsVisible="False" Clicked="OnPayClicked" Margin="0,4,0,0"/>

                <!-- Cancel Booking (both roles, hidden when terminal) -->
                <Button x:Name="CancelButton" Text="✖  CANCEL BOOKING"
                        BackgroundColor="White" BorderColor="#e74c3c" BorderWidth="1.5"
                        TextColor="#e74c3c" CornerRadius="12" HeightRequest="52"
                        FontAttributes="Bold" Clicked="OnCancelClicked"/>

                <!-- Logout -->
                <Button Text="↩  LOGOUT TO SWITCH ACCOUNT" BackgroundColor="Transparent"
                        BorderColor="#CCCCCC" BorderWidth="1" TextColor="#888888"
                        CornerRadius="12" HeightRequest="48" FontSize="12"
                        Clicked="OnLogoutClicked" Margin="0,8,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
