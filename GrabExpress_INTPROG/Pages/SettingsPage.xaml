<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GrabExpress_INTPROG.Pages.SettingsPage"
             Title="Settings"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">
    
    <Grid RowDefinitions="Auto, *">
        <!-- Custom Header with Back Button -->
        <Border Grid.Row="0" BackgroundColor="#00B14F" StrokeThickness="0" Padding="15,10">
            <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                <Label Text="←" 
                       TextColor="White" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center"
                       Padding="10,0,10,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Text="Settings" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">
            
            <Label Text="No customizable settings available." FontSize="16" TextColor="#666666" HorizontalOptions="Center" Margin="0,50,0,0" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
