<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GrabExpress_INTPROG.Pages.SplashScreenPage"
             BackgroundColor="#00B14F"
             NavigationPage.HasNavigationBar="False">
    
    <Grid>
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
            <Image Source="grab_logo_white.png" 
                   HeightRequest="100" 
                   WidthRequest="200" />
            
            <ActivityIndicator IsRunning="True" 
                               Color="White" 
                               HorizontalOptions="Center" />
            
            <Label Text="GrabExpress"
                   TextColor="White"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            
            <Label Text="Express Delivery, Simplified"
                   TextColor="White"
                   FontSize="16"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>
        
        <Label Text="© 2026 GrabExpress. All rights reserved."
               TextColor="White"
               FontSize="12"
               VerticalOptions="End"
               HorizontalOptions="Center"
               Margin="0,0,0,20" />
    </Grid>
</ContentPage>
