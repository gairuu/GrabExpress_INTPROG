<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GrabExpress_INTPROG.Pages.ForgotPasswordPage"
             Title="Forgot Password"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False"
             SizeChanged="OnPageSizeChanged">
    
    <Grid RowDefinitions="Auto, *">
        <!-- Custom Header with Back Button -->
        <Border Grid.Row="0" BackgroundColor="#00B14F" StrokeThickness="0" Padding="15,10">
            <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                <Label Text="←" 
                       TextColor="White" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center"
                       Padding="10,0,10,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Text="Forgot Password" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>
 
        <VerticalStackLayout x:Name="FormCard" Grid.Row="1" Padding="30" Spacing="25" VerticalOptions="Center" MaximumWidthRequest="400" HorizontalOptions="Center">
        
        <Image Source="forgot_password_icon.png"
               HeightRequest="120"
               HorizontalOptions="Center"
               Margin="0,0,0,20"/>

        <Label Text="Forgot Password?"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="#333333"
               HorizontalOptions="Center" />

        <Label Text="Enter your email address and we'll send you a link to reset your password."
               FontSize="16"
               TextColor="#666666"
               HorizontalTextAlignment="Center"
               Margin="0,-10,0,20"/>

        <Border Stroke="#E0E0E0" StrokeShape="RoundRectangle 8" StrokeThickness="1" Padding="10,0">
            <Entry Placeholder="Email Address" Keyboard="Email" TextColor="#333333"/>
        </Border>

        <Button Text="SEND RESET LINK"
                BackgroundColor="#00B14F"
                TextColor="White"
                CornerRadius="8"
                HeightRequest="50"
                FontAttributes="Bold"
                Margin="0,20,0,0"
                Clicked="OnResetClicked" />

        <Label Text="Back to Login"
               TextColor="#00B14F"
               FontSize="14"
               HorizontalOptions="Center"
               FontAttributes="Bold">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackTapped" />
            </Label.GestureRecognizers>
        </Label>

        </VerticalStackLayout>
    </Grid>
</ContentPage>
