@inject DatabaseService DatabaseService
@inject ILocalStorageService LocalStorage

<div class="booking-container">
    <!-- Green Header -->
    <div class="booking-header text-white p-4 d-flex align-items-center">
        <button class="btn btn-link text-white p-0 me-3" @onclick='() => OnViewChanged.InvokeAsync("Dashboard")'>
            <i class="bi bi-arrow-left fs-4"></i>
        </button>
        <div>
            <div class="h4 mb-0 fw-bold">Book a Delivery</div>
            <div class="small opacity-75">Fast, safe, and reliable</div>
        </div>
    </div>

    <!-- White Body -->
    <div class="booking-body p-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <!-- Pickup -->
            <div class="mb-4">
                <div class="d-flex align-items-center mb-2">
                    <span class="me-2">📍</span>
                    <span class="fw-bold text-muted small uppercase">Pickup Location</span>
                </div>
                <input type="text" class="form-control border-0 bg-light p-3 rounded-3" 
                       placeholder="Where to pick up from?" @bind="pickup" />
            </div>

            <!-- Divider with Swap -->
            <div class="position-relative text-center my-2">
                <hr class="opacity-10" />
                <button class="btn btn-light shadow-sm rounded-circle position-absolute top-50 start-50 translate-middle"
                        style="width: 40px; height: 40px;" @onclick="SwapLocations">
                    <i class="bi bi-arrow-down-up text-success"></i>
                </button>
            </div>

            <!-- Drop-off -->
            <div class="mt-4">
                <div class="d-flex align-items-center mb-2">
                    <span class="me-2">🏁</span>
                    <span class="fw-bold text-muted small uppercase">Drop-off Location</span>
                </div>
                <input type="text" class="form-control border-0 bg-light p-3 rounded-3" 
                       placeholder="Where to deliver to?" @bind="dropoff" />
            </div>
        </div>

        <!-- Calculate Button -->
        <button class="btn btn-success w-100 p-3 rounded-4 fw-bold shadow-sm" @onclick="CalculateFee">
            <span class="me-2">🔍</span> CALCULATE DELIVERY FEE
        </button>

        @if (fee > 0)
        {
            <div class="mt-4 p-3 bg-white rounded-4 border text-center shadow-sm animated-fade-in">
                <div class="text-muted small mb-1">Estimated Fee</div>
                <div class="h3 fw-bold text-success">₱@fee.ToString("F2")</div>
                <button class="btn btn-success w-100 mt-3 rounded-pill" @onclick="ConfirmBooking">Confirm & Pay</button>
            </div>
        }
    </div>
</div>

<style>
    .booking-container {
        max-width: 500px;
        margin: 0 auto;
        min-height: 100vh;
        background-color: #f8f9fa;
    }
    .booking-header {
        background-color: #00b14f;
    }
    .text-success {
        color: #00b14f !important;
    }
    .btn-success {
        background-color: #00b14f;
        border-color: #00b14f;
    }
    .animated-fade-in {
        animation: fadeIn 0.3s ease-in;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [Parameter] public EventCallback<string> OnViewChanged { get; set; }
    private string pickup = "";
    private string dropoff = "";
    private decimal fee = 0;

    private void SwapLocations()
    {
        var temp = pickup;
        pickup = dropoff;
        dropoff = temp;
    }

    private void CalculateFee()
    {
        if (string.IsNullOrWhiteSpace(pickup) || string.IsNullOrWhiteSpace(dropoff)) return;
        fee = DatabaseService.CalculateDeliveryFee(pickup, dropoff);
    }

    private async Task ConfirmBooking()
    {
        // This would involve saving to Firebase and redirecting to a Tracking view
        // For now, let's just go back
        await OnViewChanged.InvokeAsync("Dashboard");
    }
}