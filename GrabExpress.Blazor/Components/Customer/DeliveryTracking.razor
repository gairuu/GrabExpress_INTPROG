@implements IDisposable
@inject DatabaseService DatabaseService
@inject ILocalStorageService LocalStorage

<div class="tracking-container">
    <!-- Green Header -->
    <div class="tracking-header text-white p-4 d-flex align-items-center">
        <button class="btn btn-link text-white p-0 me-3" @onclick='() => OnViewChanged.InvokeAsync("Dashboard")'>
            <i class="bi bi-arrow-left fs-4"></i>
        </button>
        <div>
            <div class="h4 mb-0 fw-bold">Track My Delivery</div>
            <div class="small opacity-75">Booking ID: @DeliveryId</div>
        </div>
    </div>

    <div class="tracking-body p-4">
        @if (delivery == null)
        {
            <div class="text-center p-5">
                <div class="spinner-border text-success" role="status"></div>
                <p class="mt-3">Fetching delivery status...</p>
            </div>
        }
        else
        {
            <!-- Status Badge -->
            <div class="status-badge-container mb-4">
                <div class="status-badge @GetStatusClass()">
                    @GetStatusIcon() @delivery.DeliveryStatus?.ToUpper()
                </div>
            </div>

            <!-- Progress Steps -->
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <div class="progress-steps">
                    <div class="step @(IsActive("Pending") ? "active" : "")">
                        <div class="step-icon"><i class="bi bi-file-earmark-plus"></i></div>
                        <div class="step-label">Booking Placed</div>
                    </div>
                    <div class="step-line @(IsLineActive("In Transit") ? "active" : "")"></div>
                    <div class="step @(IsActive("In Transit") ? "active" : "")">
                        <div class="step-icon"><i class="bi bi-truck"></i></div>
                        <div class="step-label">In Transit</div>
                    </div>
                    <div class="step-line @(IsLineActive("Delivered") ? "active" : "")"></div>
                    <div class="step @(IsActive("Delivered") || IsActive("Completed") ? "active" : "")">
                        <div class="step-icon"><i class="bi bi-check-circle"></i></div>
                        <div class="step-label">Delivered</div>
                    </div>
                </div>
            </div>

            <!-- Route Info -->
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h6 class="fw-bold text-muted small text-uppercase mb-3">Delivery Route</h6>
                <div class="d-flex mb-3">
                    <div class="route-icons me-3">
                        <div class="dot green"></div>
                        <div class="line"></div>
                        <div class="dot red"></div>
                    </div>
                    <div class="route-details w-100">
                        <div class="mb-3">
                            <div class="small text-muted">Pickup</div>
                            <div class="fw-bold">@delivery.PickupLocation</div>
                        </div>
                        <div>
                            <div class="small text-muted">Drop-off</div>
                            <div class="fw-bold">@delivery.DropoffLocation</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Driver Info (If Assigned) -->
            @if (!string.IsNullOrEmpty(delivery.DriverId))
            {
                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 border-start border-success border-4">
                    <h6 class="fw-bold text-muted small text-uppercase mb-3">Driver Assigned</h6>
                    <div class="d-flex align-items-center">
                        <div class="driver-avatar bg-success text-white me-3">
                            <i class="bi bi-person"></i>
                        </div>
                        <div>
                            <div class="h5 mb-0 fw-bold">@driverName</div>
                            <div class="small text-muted">@vehicleInfo</div>
                        </div>
                    </div>
                </div>
            }

            @if (delivery.DeliveryStatus == "Pending")
            {
                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-light text-center border-dashed">
                    <div class="spinner-grow spinner-grow-sm text-success me-2" role="status"></div>
                    <span class="text-muted fw-bold">Searching for nearby drivers...</span>
                </div>
            }
            else if (delivery.DeliveryStatus == "Payment Pending")
            {
                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white">
                    <h5 class="fw-bold mb-3 text-success">💳 Payment Required</h5>
                    <p class="text-muted small">Your package has arrived! Please complete the payment so the driver can hand it over.</p>
                    
                    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-light rounded-3">
                        <div>
                            <div class="small text-muted mb-1">Total Fee</div>
                            <div class="h4 mb-0 fw-bold text-success">₱@delivery.DeliveryFee.ToString("N2")</div>
                        </div>
                    </div>
                    
                    <h6 class="fw-bold text-muted small text-uppercase mb-2">Select Payment Method</h6>
                    <div class="row g-2 mb-4">
                        <div class="col-6">
                            <div class="p-3 border rounded-3 text-center cursor-pointer @(selectedPaymentMethod == "GrabPay" ? "border-success bg-success-light text-success fw-bold" : "")" @onclick='() => selectedPaymentMethod = "GrabPay"'>
                                🟢 GrabPay
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 border rounded-3 text-center cursor-pointer @(selectedPaymentMethod == "Cash" ? "border-success bg-success-light text-success fw-bold" : "")" @onclick='() => selectedPaymentMethod = "Cash"'>
                                💵 Cash
                            </div>
                        </div>
                    </div>
                    
                    @if (isPaying)
                    {
                        <button class="btn btn-success w-100 p-3 rounded-pill shadow-sm fw-bold" disabled>
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            PROCESSING PAYMENT...
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-success w-100 p-3 rounded-pill shadow-sm fw-bold" @onclick="ProcessPayment">
                            CONFIRM & PAY ₱@delivery.DeliveryFee.ToString("N2")
                        </button>
                    }
                </div>
            }
            else if (delivery.DeliveryStatus == "Paid")
            {
                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white text-center border-success border-2">
                    <div class="spinner-grow spinner-grow-sm text-success me-2" role="status"></div>
                    <span class="text-success fw-bold">Payment successful! The driver will now hand over your package.</span>
                </div>
            }

            @if (delivery.DeliveryStatus == "Pending" || delivery.DeliveryStatus == "Assigned" || delivery.DeliveryStatus == "In Transit")
            {
                <button class="btn btn-outline-danger w-100 p-3 rounded-4 fw-bold mt-2" @onclick="CancelBooking">
                    CANCEL BOOKING
                </button>
            }
        }
    </div>
</div>

<style>
    .tracking-container {
        max-width: 600px;
        margin: 0 auto;
        min-height: 100vh;
        background-color: #f8f9fa;
    }
    .tracking-header {
        background-color: #00b14f;
    }
    .status-badge {
        padding: 12px 20px;
        border-radius: 12px;
        font-weight: 800;
        text-align: center;
        letter-spacing: 1px;
    }
    .status-badge.pending { background: #fff8e1; color: #f57f17; }
    .status-badge.in-transit { background: #e8f5e9; color: #00b14f; }
    .status-badge.delivered { background: #e3f2fd; color: #1565c0; }
    .status-badge.cancelled { background: #ffebee; color: #c62828; }

    .progress-steps {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .step {
        display: flex;
        flex-direction: column;
        align-items: center;
        z-index: 2;
        color: #ddd;
    }
    .step.active { color: #00b14f; }
    .step-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #eee;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 5px;
    }
    .step.active .step-icon { background: #e6f7ed; }
    .step-label { font-size: 0.75rem; font-weight: bold; }
    .step-line {
        flex-grow: 1;
        height: 3px;
        background: #eee;
        margin: 0 10px;
        margin-top: -20px;
    }
    .step-line.active { background: #00b14f; }

    .route-icons {
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .dot { width: 12px; height: 12px; border-radius: 50%; }
    .dot.green { background: #00b14f; }
    .dot.red { background: #dc3545; }
    .line { width: 2px; height: 40px; background: #ddd; }

    .driver-avatar {
        width: 50px;
        height: 50px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    .border-dashed { border: 2px dashed #ddd; }
    .cursor-pointer { cursor: pointer; }
    .bg-success-light { background-color: rgba(0, 177, 79, 0.1); }
</style>

@code {
    [Parameter] public string DeliveryId { get; set; } = "";
    [Parameter] public EventCallback<string> OnViewChanged { get; set; }

    private Delivery? delivery;
    private string driverName = "Searching...";
    private string vehicleInfo = "";
    private IDisposable? listener;
    private string selectedPaymentMethod = "GrabPay";
    private bool isPaying = false;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(DeliveryId))
        {
            listener = DatabaseService.ListenToDelivery(DeliveryId, async (updated) =>
            {
                await InvokeAsync(async () => 
                {
                    try
                    {
                        delivery = updated;
                        if (delivery != null && !string.IsNullOrEmpty(delivery.DriverId))
                        {
                            var driver = await DatabaseService.GetDriverAsync(delivery.DriverId);
                            if (driver != null)
                            {
                                driverName = driver.Name ?? "Driver";
                                var vehicle = await DatabaseService.GetVehicleAsync(delivery.DriverId);
                                vehicleInfo = vehicle != null ? $"{vehicle.Color} {vehicle.VehicleModel} · {vehicle.PlateNumber}" : "Vehicle info pending";
                            }
                        }
                        StateHasChanged();
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Tracking update error: {ex.Message}");
                    }
                });
            });
        }
    }

    private string GetStatusClass() => delivery?.DeliveryStatus?.ToLower().Replace(" ", "-") ?? "pending";
    private string GetStatusIcon() => delivery?.DeliveryStatus switch
    {
        "Pending" => "🔍",
        "In Transit" => "🚗",
        "Payment Pending" => "💳",
        "Paid" => "✅",
        "Completed" => "✅",
        "Cancelled" => "✖",
        _ => "📦"
    };

    private bool IsActive(string status) 
    {
        if (delivery == null) return false;
        if (delivery.DeliveryStatus == "Cancelled") return false;
        if (status == "Pending") return true;
        if (status == "In Transit") return delivery.DeliveryStatus == "In Transit" || delivery.DeliveryStatus == "Payment Pending" || delivery.DeliveryStatus == "Paid" || delivery.DeliveryStatus == "Delivered" || delivery.DeliveryStatus == "Completed";
        if (status == "Delivered") return delivery.DeliveryStatus == "Delivered" || delivery.DeliveryStatus == "Completed";
        return false;
    }

    private bool IsLineActive(string status) => IsActive(status);

    private async Task CancelBooking()
    {
        if (delivery == null) return;
        try
        {
            await DatabaseService.UpdateDeliveryStatusAsync(DeliveryId, "Cancelled");
            if (!string.IsNullOrEmpty(delivery.DriverId))
            {
                await DatabaseService.UpdateDriverStatusAsync(delivery.DriverId, "Available");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Cancel error: {ex.Message}");
        }
    }

    private async Task ProcessPayment()
    {
        if (isPaying || delivery == null) return;
        isPaying = true;
        try
        {
            await DatabaseService.UpdateDeliveryStatusAsync(DeliveryId, "Paid");
            // Note: We don't free the driver here anymore. The driver is freed when they click "Mark as Delivered" which sets it to Completed.
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Payment error: {ex.Message}");
        }
        finally
        {
            isPaying = false;
        }
    }

    public void Dispose()
    {
        listener?.Dispose();
    }
}