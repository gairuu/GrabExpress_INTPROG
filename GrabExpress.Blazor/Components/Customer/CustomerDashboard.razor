@inject DatabaseService DatabaseService
@inject ILocalStorageService LocalStorage

@if (customer == null)
{
    <div class="d-flex justify-content-center align-items-center vh-100">
        <div class="spinner-border text-success" role="status"></div>
    </div>
}
else
{
    <div class="customer-dashboard-wrapper">
        <!-- Premium Gradient Header -->
        <div class="dashboard-banner p-5 text-white shadow-sm">
            <div class="container-fluid p-0">
                <div class="row align-items-center">
                    <div class="col-12">
                        <div class="d-flex align-items-center mb-2">
                            <div class="premium-avatar shadow-sm me-3">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <div>
                                <h6 class="text-uppercase small fw-bold opacity-75 mb-0">Member Dashboard</h6>
                                <h2 class="fw-bolder mb-0">Hello, @customer.Name! 👋</h2>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Floating Service Cards Area -->
        <div class="container-fluid px-5 dashboard-content-area">
            <div class="row g-4">
                <!-- Express Booking Card Full Width -->
                <div class="col-12">
                    <div class="main-service-card shadow-lg p-4 rounded-5 border-0 position-relative overflow-hidden" @onclick='() => OnViewChanged.InvokeAsync("Booking")'>
                        <div class="row align-items-center position-relative" style="z-index: 2;">
                            <div class="col-md-7 text-start">
                                <span class="badge bg-white text-success mb-3 px-3 py-2 fw-bold">POPULAR SERVICE</span>
                                <h1 class="h2 fw-bolder mb-3">Express Delivery</h1>
                                <p class="lead opacity-75 mb-4">Need to send a package right now? Our riders are ready to pick up your parcel in minutes.</p>
                                <button class="btn btn-light btn-lg px-5 rounded-pill fw-bold text-success shadow">
                                    Book Now <i class="bi bi-arrow-right ms-2"></i>
                                </button>
                            </div>
                            <div class="col-md-5 d-none d-md-block text-end pe-5">
                                <div class="floating-box-medium">📦</div>
                            </div>
                        </div>
                        <div class="card-bg-decoration"></div>
                    </div>
                </div>
            </div>

        </div>

            <!-- Booking History Card -->
            <div class="mt-5 pb-5">
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="mini-service-card shadow-sm p-4 bg-white rounded-5 text-center" @onclick='() => OnViewChanged.InvokeAsync("History")'>
                            <div class="icon-sq-bg mb-3 mx-auto" style="background-color: #f1f1ff;"><i class="bi bi-journal-text fs-3 text-primary"></i></div>
                            <h5 class="fw-bold">Booking History</h5>
                            <p class="small text-muted mb-0">View all your past and active deliveries here.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
}

<style>
    .customer-dashboard-wrapper {
        min-height: 100vh;
        background-color: #f0f2f5;
    }
    .dashboard-banner {
        background: linear-gradient(135deg, #00b14f 0%, #00813a 100%);
        padding-bottom: 50px !important;
    }
    .premium-avatar {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.2);
        border: 2px solid white;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
    }
    .dashboard-content-area {
        margin-top: 30px;
    }
    .main-service-card {
        background: linear-gradient(135deg, #00b14f 0%, #009140 100%);
        color: white;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .main-service-card:hover {
        transform: scale(1.02);
        box-shadow: 0 20px 40px rgba(0, 177, 79, 0.2) !important;
    }
    .card-bg-decoration {
        position: absolute;
        bottom: -50px;
        right: -50px;
        width: 250px;
        height: 250px;
        background: white;
        border-radius: 50%;
        opacity: 0.1;
        z-index: 1;
    }
    .floating-box-medium {
        font-size: 8rem;
        animation: floatDash 3s ease-in-out infinite;
    }
    .icon-circle {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }
    .icon-sq-bg {
        width: 60px;
        height: 60px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .mini-service-card {
        cursor: pointer;
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }
    .mini-service-card:hover {
        transform: translateY(-8px);
        border-color: #00b14f;
        background: #f0fdf4 !important;
    }
    .bg-success-light { background-color: rgba(0, 177, 79, 0.1); }
    .bg-primary-light { background-color: rgba(13, 110, 253, 0.1); }

    @@keyframes floatDash {
        0% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-15px) rotate(3deg); }
        100% { transform: translateY(0px) rotate(0deg); }
    }
</style>

@code {
    [Parameter] public EventCallback<string> OnViewChanged { get; set; }
    private Customer? customer;

    protected override async Task OnInitializedAsync()
    {
        var uid = await LocalStorage.GetItemAsync<string>("userUid");
        if (!string.IsNullOrEmpty(uid))
        {
            customer = await DatabaseService.GetUserProfileAsync(uid);
        }
    }
}