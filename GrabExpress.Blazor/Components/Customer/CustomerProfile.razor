@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ILocalStorageService LocalStorage

<div class="profile-container">
    <!-- Green Header -->
    <div class="profile-header text-white p-4 d-flex align-items-center">
        <button class="btn btn-link text-white p-0 me-3" @onclick='() => OnViewChanged.InvokeAsync("Dashboard")'>
            <i class="bi bi-arrow-left fs-4"></i>
        </button>
        <div class="h4 mb-0 fw-bold">Profile</div>
    </div>

    <!-- White Body -->
    <div class="profile-body p-5 d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
        <div class="text-muted h5 mb-5">@userEmail</div>

        <button class="btn btn-danger w-100 p-3 rounded-4 fw-bold shadow-sm mt-auto" @onclick="HandleLogout">
            LOG OUT
        </button>
    </div>
</div>

<style>
    .profile-container {
        max-width: 500px;
        margin: 0 auto;
        min-height: 100vh;
        background-color: #ffffff;
    }
    .profile-header {
        background-color: #00b14f;
    }
</style>

@code {
    [Parameter] public EventCallback<string> OnViewChanged { get; set; }
    private string? userEmail;

    protected override async Task OnInitializedAsync()
    {
        userEmail = await LocalStorage.GetItemAsync<string>("userEmail");
    }

    private async Task HandleLogout()
    {
        try
        {
            await AuthService.LogoutAsync();
            NavigationManager.NavigateTo("/", true); // Force reload to ensure clean state
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Logout error: {ex.Message}");
            // Fallback: just clear storage and redirect
            await LocalStorage.ClearAsync();
            NavigationManager.NavigateTo("/", true);
        }
    }
}