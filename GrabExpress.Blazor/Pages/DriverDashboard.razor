@page "/driver-dashboard"
@using GrabExpress.Blazor.Models
@using GrabExpress.Blazor.Services
@using GrabExpress.Blazor.Components.Driver
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@implements IDisposable
@attribute [Authorize(Roles = "Driver")]
@inject DatabaseService DbService
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage

<div class="container py-4">
    @if (currentDriver == null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-grab" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Header Section -->
            <div class="col-12">
                <div class="card border-0 shadow-sm p-4" style="border-radius: 15px; background: linear-gradient(135deg, #00b14f 0%, #009241 100%); color: white;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3 class="fw-bold mb-1">Hello, @currentDriver.Name!</h3>
                            <p class="mb-0 opacity-75">Ready for your next delivery?</p>
                        </div>
                        <div class="text-end">
                            <div class="form-check form-switch custom-switch">
                                <input class="form-check-input" type="checkbox" role="switch" id="onlineSwitch" checked="@isOnline" @onchange="ToggleOnlineStatus">
                                <label class="form-check-label fw-bold ms-2" for="onlineSwitch">
                                    @(isOnline ? "ONLINE" : "OFFLINE")
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Section -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 p-4" style="border-radius: 15px;">
                    <div class="small text-muted fw-bold mb-2">TODAY'S EARNINGS</div>
                    <div class="h2 fw-bold text-grab mb-0">₱@todayEarnings.ToString("N2")</div>
                    <div class="mt-3">
                        <span class="badge bg-light text-grab border">@completedToday deliveries</span>
                    </div>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="col-md-8">
                @if (activeJob != null)
                {
                    <ActiveJobCard Job="@activeJob" OnStatusChanged="RefreshDashboard" />
                }
                else if (isOnline)
                {
                    <div class="card border-0 shadow-sm p-5 text-center" style="border-radius: 15px; border: 2px dashed #ddd !important;">
                        <div class="mb-3">
                            <i class="bi bi-radar h1 text-grab pulse"></i>
                        </div>
                        <h5 class="fw-bold">Finding jobs...</h5>
                        <p class="text-muted">Stay on this page to receive new delivery requests.</p>
                    </div>
                }
                else
                {
                    <div class="card border-0 shadow-sm p-5 text-center bg-light" style="border-radius: 15px;">
                        <div class="mb-3">
                            <i class="bi bi-moon-stars h1 text-muted"></i>
                        </div>
                        <h5 class="fw-bold text-muted">You are currently offline</h5>
                        <p class="text-muted">Go online to start receiving delivery requests.</p>
                        <button class="btn btn-grab px-4 py-2 mt-2 fw-bold" @onclick="() => ToggleOnlineStatus(new ChangeEventArgs { Value = true })">Go Online</button>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    .text-grab { color: #00b14f; }
    .bg-grab { background-color: #00b14f; }
    .btn-grab { 
        background-color: #00b14f; 
        color: white; 
        border: none;
    }
    .btn-grab:hover {
        background-color: #009241;
        color: white;
    }
    
    .custom-switch .form-check-input {
        width: 3rem;
        height: 1.5rem;
        cursor: pointer;
    }
    .custom-switch .form-check-input:checked {
        background-color: #ffffff;
        border-color: #ffffff;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='-4 -4 8 8'%3e%3ccircle r='3' fill='%2300b14f'/%3e%3c/svg%3e");
    }
    
    .pulse {
        display: inline-block;
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.2); opacity: 0.7; }
        100% { transform: scale(1); opacity: 1; }
    }
</style>

@code {
    private Driver? currentDriver;
    private Delivery? activeJob;
    private bool isOnline;
    private decimal todayEarnings = 0;
    private int completedToday = 0;
    private string? userId;
    private IDisposable? _deliverySubscription;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value 
                     ?? user.FindFirst("sub")?.Value;
            
            if (string.IsNullOrEmpty(userId))
            {
                userId = await LocalStorage.GetItemAsync<string>(StorageKeys.UserUid);
            }

            if (!string.IsNullOrEmpty(userId))
            {
                currentDriver = await DbService.GetDriverAsync(userId);
                
                if (currentDriver != null)
                {
                    isOnline = currentDriver.Status == "Available" || currentDriver.Status == "Busy";
                    await RefreshDashboard();
                    
                    // Setup real-time listener for jobs
                    _deliverySubscription = DbService.GetFirebaseClient()
                        .Child("Deliveries")
                        .AsObservable<Delivery>()
                        .Subscribe(_ => InvokeAsync(RefreshDashboard));
                }
            }
        }
        else
        {
            Navigation.NavigateTo("/login");
        }
    }

    private async Task RefreshDashboard()
    {
        if (userId == null) return;

        var jobs = await DbService.GetDriverJobsAsync(userId);
        
        // Active job is anything that's not Completed or Cancelled
        activeJob = jobs.FirstOrDefault(j => j.DeliveryStatus != "Completed" && j.DeliveryStatus != "Cancelled");
        
        // Stats
        var today = DateTime.UtcNow.Date;
        var todayJobs = jobs.Where(j => j.BookingTime.Date == today && j.DeliveryStatus == "Completed").ToList();
        todayEarnings = todayJobs.Sum(j => j.DeliveryFee);
        completedToday = todayJobs.Count;

        StateHasChanged();
    }

    private async Task ToggleOnlineStatus(ChangeEventArgs e)
    {
        if (currentDriver == null || userId == null) return;

        isOnline = (bool)(e.Value ?? false);
        string newStatus = isOnline ? "Available" : "Offline";
        
        // If they have an active job, they should be Busy, not Available
        if (isOnline && activeJob != null)
        {
            newStatus = "Busy";
        }
        
        await DbService.UpdateDriverStatusAsync(userId, newStatus);
        currentDriver.Status = newStatus;
        
        StateHasChanged();
    }

    public void Dispose()
    {
        _deliverySubscription?.Dispose();
    }
}

