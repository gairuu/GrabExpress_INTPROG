@page "/register"
@inject AuthService AuthService
@inject DatabaseService DatabaseService
@inject NavigationManager NavigationManager
@using Firebase.Auth

<div class="auth-wrapper">
    <div class="auth-card shadow-lg p-5 rounded-4 bg-white">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-dark">Create account</h2>
            <p class="text-muted">Fill in the details to join GrabExpress.</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger py-2 small">@errorMessage</div>
        }

        <div class="form-group mb-3">
            <label class="form-label small fw-bold text-muted text-uppercase mb-1">Full Name</label>
            <input type="text" class="form-control p-3 bg-light border-0 rounded-3" 
                   placeholder="John Doe" @bind="fullName" />
        </div>

        <div class="form-group mb-3">
            <label class="form-label small fw-bold text-muted text-uppercase mb-1">Email Address</label>
            <input type="email" class="form-control p-3 bg-light border-0 rounded-3" 
                   placeholder="you@example.com" @bind="email" />
        </div>

        <div class="form-group mb-4">
            <label class="form-label small fw-bold text-muted text-uppercase mb-1">Password</label>
            <input type="password" class="form-control p-3 bg-light border-0 rounded-3" 
                   placeholder="••••••••" @bind="password" />
        </div>

        <button class="btn btn-success w-100 p-3 rounded-3 fw-bold d-flex align-items-center justify-content-center" @onclick="HandleRegister" disabled="@isProcessing">
            @if (isProcessing)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            }
            Get Started <i class="bi bi-arrow-right ms-2"></i>
        </button>

        <div class="text-center mt-4">
            <p class="small text-muted mb-0">Already have an account? <a href="/login" class="text-success fw-bold text-decoration-none">Log in</a></p>
        </div>
    </div>
</div>

<style>
    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f8f9fa;
        padding: 20px;
    }
    .auth-card {
        width: 100%;
        max-width: 450px;
        border: 1px solid #eee;
    }
    .form-control:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(0, 177, 79, 0.1);
        border: 1px solid #00b14f !important;
    }
    .btn-success {
        background-color: #00b14f;
        border-color: #00b14f;
        font-size: 1.1rem;
    }
    .btn-success:hover {
        background-color: #009140;
        border-color: #009140;
    }
    .text-success {
        color: #00b14f !important;
    }
</style>

@code {
    private string email = "";
    private string password = "";
    private string fullName = "";
    private string errorMessage = "";
    private bool isProcessing = false;

    private async Task HandleRegister()
    {
        if (isProcessing) return;

        try
        {
            isProcessing = true;
            errorMessage = "";
            var creds = await AuthService.RegisterAsync(email, password);
            
            var customer = new Customer
            {
                Name = fullName,
                Email = email,
                ContactNumber = ""
            };
            
            await DatabaseService.SaveUserProfileAsync(creds.User.Uid, customer);
            await DatabaseService.SaveUserRoleAsync(creds.User.Uid, "Customer");

            NavigationManager.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }
}