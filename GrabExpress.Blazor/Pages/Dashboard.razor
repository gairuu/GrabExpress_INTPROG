@page "/dashboard"
@attribute [Authorize]
@inject DatabaseService DatabaseService
@inject ILocalStorageService LocalStorage

@if (isLoading)
{
    <div class="p-5 text-center">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3">Loading your dashboard...</p>
    </div>
}
else if (userRole == "Admin")
{
    <div class="container p-4">
        <h3 class="fw-bold">Admin Dashboard</h3>
        <div class="alert alert-info">Admin features are coming soon...</div>
    </div>
}
else if (userRole == "Driver")
{
    <div class="container p-4">
        <h3 class="fw-bold text-success">Driver Dashboard</h3>
        <div class="alert alert-info">Driver features are coming soon...</div>
    </div>
}
else if (userRole == "Customer" || userRole == null)
{
    @if (currentView == "Dashboard")
    {
        <CustomerDashboard OnViewChanged="ChangeView" />
    }
    else if (currentView == "Booking")
    {
        <BookingForm OnViewChanged="ChangeView" />
    }
    else if (currentView == "Profile")
    {
        <CustomerProfile OnViewChanged="ChangeView" />
    }
    else
    {
        <CustomerDashboard OnViewChanged="ChangeView" />
    }
}

@code {
    private bool isLoading = true;
    private string? userRole;
    private string currentView = "Dashboard";

    protected override async Task OnInitializedAsync()
    {
        var uid = await LocalStorage.GetItemAsync<string>("userUid");
        if (!string.IsNullOrEmpty(uid))
        {
            userRole = await DatabaseService.GetUserRoleAsync(uid);
            // Remove outer quotes if returned by Firebase
            if (!string.IsNullOrEmpty(userRole) && userRole.StartsWith("\"") && userRole.EndsWith("\""))
            {
                userRole = userRole.Substring(1, userRole.Length - 2);
            }
        }
        isLoading = false;
    }

    private void ChangeView(string newView)
    {
        currentView = newView;
    }
}