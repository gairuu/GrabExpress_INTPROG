@page "/dashboard"
@attribute [Authorize]
@inject DatabaseService DatabaseService
@inject ILocalStorageService LocalStorage
@inject NavigationManager NavigationManager

@if (isLoading)
{
    <div class="p-5 text-center">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3">Loading your dashboard...</p>
    </div>
}
else if (userRole == "Customer" || userRole == "Admin" || userRole == null)
{
    <div class="dashboard-content">
        @if (currentView == "Dashboard")
        {
            <CustomerDashboard OnViewChanged="ChangeView" />
        }
        else if (currentView == "Booking")
        {
            <BookingForm OnViewChanged="ChangeView" />
        }
        else if (currentView == "Tracking" && !string.IsNullOrEmpty(selectedDeliveryId))
        {
            <DeliveryTracking DeliveryId="@selectedDeliveryId" OnViewChanged="ChangeView" />
        }
        else if (currentView == "Profile")
        {
            <CustomerProfile OnViewChanged="ChangeView" />
        }

        else if (currentView == "History")
        {
            <DeliveryHistory OnViewChanged="ChangeView" />
        }
        else
        {
            <CustomerDashboard OnViewChanged="ChangeView" />
        }
    </div>
}

@code {
    private bool isLoading = true;
    private string? userRole;
    private string currentView = "Dashboard";
    private string? selectedDeliveryId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var uid = await LocalStorage.GetItemAsync<string>(StorageKeys.UserUid);
            if (!string.IsNullOrEmpty(uid))
            {
                userRole = await DatabaseService.GetUserRoleAsync(uid);

                if (userRole == "Driver")
                {
                    NavigationManager.NavigateTo("/driver-dashboard");
                    return;
                }
                if (userRole == "Admin")
                {
                    // Admins stay here
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Dashboard init error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ChangeView(string newView)
    {
        if (newView.StartsWith("Tracking:"))
        {
            selectedDeliveryId = newView.Substring(9);
            currentView = "Tracking";
        }
        else
        {
            currentView = newView;
        }
    }
}