<div class="nav-container h-100 d-flex flex-column">
    <div class="top-row ps-4 navbar navbar-light border-bottom">
        <div class="container-fluid p-0">
            <a class="navbar-brand fw-bold text-success d-flex align-items-center" href="">
                <i class="bi bi-box-seam-fill me-2"></i> GrabExpress
            </a>
        </div>
    </div>

    <div class="nav-scrollable flex-grow-1 py-3" onclick="document.querySelector('.navbar-toggler')?.click()">
        <nav class="flex-column px-2">
            <div class="nav-item mb-1">
                <NavLink class="nav-link rounded-3 px-3 py-2" href="" Match="NavLinkMatch.All">
                    <i class="bi bi-house-door-fill me-3"></i> Home
                </NavLink>
            </div>
            
            <AuthorizeView>
                <Authorized>
                    <div class="nav-item mb-1">
                        <NavLink class="nav-link rounded-3 px-3 py-2" href="dashboard">
                            <i class="bi bi-grid-1x2-fill me-3"></i> Dashboard
                        </NavLink>
                    </div>
                    <div class="mt-auto pt-4 border-top mx-2">
                        <div class="nav-item">
                            <button class="nav-link btn btn-link w-100 text-start rounded-3 px-3 py-2 text-danger" @onclick="Logout">
                                <i class="bi bi-box-arrow-right me-3"></i> Logout
                            </button>
                        </div>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="nav-item">
                        <NavLink class="nav-link rounded-3 px-3 py-2" href="login">
                            <i class="bi bi-person-fill me-3"></i> Login
                        </NavLink>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </nav>
    </div>
</div>

<style>
    .nav-link {
        color: #555;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        font-weight: 500;
        border: 1px solid transparent;
    }
    .nav-link:hover {
        background-color: #f0fdf4;
        color: #00b14f;
    }
    .nav-link.active {
        background-color: #e6f7ed;
        color: #00b14f;
        font-weight: 600;
    }
    .text-success {
        color: #00b14f !important;
    }
    .text-danger:hover {
        background-color: #fff5f5;
        color: #dc3545 !important;
    }
    .navbar-brand {
        font-size: 1.25rem;
        letter-spacing: -0.5px;
    }
    i {
        font-size: 1.1rem;
    }
</style>

@code {
    [Inject] private AuthService AuthService { get; set; } = default!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/");
    }
}